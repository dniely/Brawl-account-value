<% if @player %>

<% 
  brawlers = @player["brawlers"]
  fullset = brawlers.select do |b|
    b["power"] == 11 && (b["gadgets"]&.size.to_i >= 1) && 
    (b["starPowers"]&.size.to_i >= 1) && (b["hyperCharges"]&.size.to_i >= 1)
  end

  brawler_value = brawlers.count * 6.5 * 48
  upgrade_value = brawlers.sum { |b| b["power"] == 11 ? 8 : (b["power"] == 10 ? 5 : 1) } * 48
  gadget_value = brawlers.sum { |b| b["gadgets"]&.size.to_i } * 1.8 * 48
  sp_value = brawlers.sum { |b| b["starPowers"]&.size.to_i } * 3.2 * 48
  hc_value = brawlers.sum { |b| b["hyperCharges"]&.size.to_i } * 7.9 * 48
  gear_value = brawlers.sum { |b| b["gears"]&.size.to_i } * 1.4 * 48
  fullset_value = fullset.count * 12 * 48
  trophy_value = @player["trophies"].to_i * 0.02 * 48

  total = brawler_value + upgrade_value + gadget_value + sp_value + hc_value + gear_value + fullset_value + trophy_value

  def percent(v, t)
    return 0 if t == 0
    ((v.to_f / t) * 100).round
  end
%>

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= @player["name"] %> - 브롤 스타즈</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@500;700&display=swap');
    body { font-family: 'Noto Sans KR', sans-serif; }
    h1, h2, h3 { font-weight: 700; }
  </style>
</head>
<body class="bg-gray-50">
  <div class="max-w-5xl mx-auto px-4 py-8">
    <div class="bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-lg p-8 mb-8">
      <div class="flex justify-between items-center">
        <div class="flex items-center gap-4">
          <div>
            <h1 class="text-4xl font-bold mb-2"><%= @player["name"] %></h1>
            <p class="text-blue-100">플레이어 통계</p>
          </div>
        </div>
        <div class="text-right">
          <div class="text-blue-100 text-sm">총 트로피</div>
          <div class="text-5xl font-bold"><%= @player["trophies"] %></div>
        </div>
      </div>
    </div>

    <div class="mb-8">
      <h2 class="text-2xl font-bold mb-4">계정 가치</h2>
      <div class="bg-white rounded-lg border border-gray-200 p-6">
        <div class="space-y-3 mb-6">
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="font-medium">브롤러</span>
              <span><%= percent(brawler_value, total) %>% (<%= brawler_value.round %>)</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="bg-blue-600 h-2 rounded-full" style="width: <%= percent(brawler_value, total) %>%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="font-medium">업그레이드</span>
              <span><%= percent(upgrade_value, total) %>% (<%= upgrade_value.round %>)</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="bg-blue-600 h-2 rounded-full" style="width: <%= percent(upgrade_value, total) %>%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="font-medium">가젯</span>
              <span><%= percent(gadget_value, total) %>% (<%= gadget_value.round %>)</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="bg-blue-600 h-2 rounded-full" style="width: <%= percent(gadget_value, total) %>%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="font-medium">스타파워</span>
              <span><%= percent(sp_value, total) %>% (<%= sp_value.round %>)</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="bg-blue-600 h-2 rounded-full" style="width: <%= percent(sp_value, total) %>%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="font-medium">하이퍼차지</span>
              <span><%= percent(hc_value, total) %>% (<%= hc_value.round %>)</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="bg-blue-600 h-2 rounded-full" style="width: <%= percent(hc_value, total) %>%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="font-medium">기어</span>
              <span><%= percent(gear_value, total) %>% (<%= gear_value.round %>)</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="bg-blue-600 h-2 rounded-full" style="width: <%= percent(gear_value, total) %>%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="font-medium">풀셋 브롤러</span>
              <span><%= percent(fullset_value, total) %>% (<%= fullset_value.round %>)</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="bg-blue-600 h-2 rounded-full" style="width: <%= percent(fullset_value, total) %>%"></div>
            </div>
          </div>
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="font-medium">트로피</span>
              <span><%= percent(trophy_value, total) %>% (<%= trophy_value.round %>)</span>
            </div>
            <div class="w-full bg-gray-200 rounded-full h-2">
              <div class="bg-blue-600 h-2 rounded-full" style="width: <%= percent(trophy_value, total) %>%"></div>
            </div>
          </div>
        </div>
        <div class="border-t pt-4 text-center">
          <div class="text-gray-600 text-sm font-medium mb-2">총 계정 가치</div>
          <div class="text-4xl font-bold text-blue-600"><%= total.round %> WON</div>
        </div>
      </div>
    </div>

    <div class="mb-8">
      <h2 class="text-2xl font-bold mb-4">통계</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-white p-4 rounded-lg border border-gray-200">
          <div class="text-gray-600 text-sm font-medium">브롤러</div>
          <div class="text-3xl font-bold text-blue-600 mt-2"><%= brawlers.count %></div>
        </div>
        <div class="bg-white p-4 rounded-lg border border-gray-200">
          <div class="text-gray-600 text-sm font-medium">11레벨</div>
          <div class="text-3xl font-bold text-blue-600 mt-2"><%= brawlers.count { |b| b["power"] == 11 } %></div>
        </div>
        <div class="bg-white p-4 rounded-lg border border-gray-200">
          <div class="text-gray-600 text-sm font-medium">10레벨</div>
          <div class="text-3xl font-bold text-blue-600 mt-2"><%= brawlers.count { |b| b["power"] == 10 } %></div>
        </div>
        <div class="bg-white p-4 rounded-lg border border-gray-200">
          <div class="text-gray-600 text-sm font-medium">9레벨</div>
          <div class="text-3xl font-bold text-blue-600 mt-2"><%= brawlers.count { |b| b["power"] == 9 } %></div>
        </div>
      </div>
    </div>

    <div class="mb-8">
      <h2 class="text-2xl font-bold mb-4">장비</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-white p-4 rounded-lg border border-gray-200">
          <div class="text-gray-600 text-sm font-medium">가젯</div>
          <div class="text-3xl font-bold text-blue-600 mt-2"><%= brawlers.sum { |b| b["gadgets"]&.size.to_i } %></div>
        </div>
        <div class="bg-white p-4 rounded-lg border border-gray-200">
          <div class="text-gray-600 text-sm font-medium">스타파워</div>
          <div class="text-3xl font-bold text-blue-600 mt-2"><%= brawlers.sum { |b| b["starPowers"]&.size.to_i } %></div>
        </div>
        <div class="bg-white p-4 rounded-lg border border-gray-200">
          <div class="text-gray-600 text-sm font-medium">하이퍼차지</div>
          <div class="text-3xl font-bold text-blue-600 mt-2"><%= brawlers.count { |b| b["hyperCharges"]&.size.to_i >= 1 } %></div>
        </div>
        <div class="bg-white p-4 rounded-lg border border-gray-200">
          <div class="text-gray-600 text-sm font-medium">기어</div>
          <div class="text-3xl font-bold text-blue-600 mt-2"><%= brawlers.sum { |b| b["gears"]&.size.to_i } %></div>
        </div>
      </div>
    </div>

    <div class="mb-8">
      <h2 class="text-2xl font-bold mb-4">특수 카테고리</h2>
      <div class="grid grid-cols-2 gap-4">
        <div class="bg-white p-4 rounded-lg border border-gray-200">
          <div class="text-gray-600 text-sm font-medium">풀셋 브롤러</div>
          <div class="text-3xl font-bold text-blue-600 mt-2"><%= fullset.count %></div>
          <div class="text-xs text-gray-500 mt-2">Lv11 + 가젯 + 스타파워 + 하이퍼차지</div>
        </div>
        <div class="bg-white p-4 rounded-lg border border-gray-200">
          <div class="text-gray-600 text-sm font-medium">맥스 티어</div>
          <div class="text-3xl font-bold text-blue-600 mt-2"><%= brawlers.select { |b| b["trophies"] >= 1000 }.count %></div>
          <div class="text-xs text-gray-500 mt-2">1000+ 트로피</div>
        </div>
      </div>
    </div>

    <div class="mb-8">
      <h2 class="text-2xl font-bold mb-4">전적</h2>
      <div class="grid grid-cols-3 gap-4">
        <div class="bg-white p-4 rounded-lg border border-gray-200 text-center">
          <div class="text-gray-600 text-sm font-medium">3vs3</div>
          <div class="text-3xl font-bold text-blue-600 mt-2"><%= @player["3vs3Victories"] %></div>
        </div>
        <div class="bg-white p-4 rounded-lg border border-gray-200 text-center">
          <div class="text-gray-600 text-sm font-medium">솔로</div>
          <div class="text-3xl font-bold text-blue-600 mt-2"><%= @player["soloVictories"] %></div>
        </div>
        <div class="bg-white p-4 rounded-lg border border-gray-200 text-center">
          <div class="text-gray-600 text-sm font-medium">듀오</div>
          <div class="text-3xl font-bold text-blue-600 mt-2"><%= @player["duoVictories"] %></div>
        </div>
      </div>
    </div>
    
    <div class="text-center mb-8">
      <a href="/" class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 font-medium">다시 검색</a>
    </div>
  </div>
</body>
</html>

<% else %>
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>오류</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
  <div class="min-h-screen flex items-center justify-center">
    <div class="text-center">
      <div class="text-6xl mb-4"></div>
      <p class="text-xl font-bold text-gray-800 mb-6"><%= @error %></p>
      <a href="/" class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 font-medium">돌아가기</a>
    </div>
  </div>
</body>
</html>
<% end %>
